    <div class="info alert alert-info">
    <i class="fa fa-money fa-fw"></i> Select your payment methods.
    </div>
    <div class="row">
	    <div class="col-sm-3 h5 center">
	        <a href="#admin#rt=extension/extensions/install&extension=paypal_commerce" target="_extension">
	        <img style="width: 94px; height: 94px;" src="extensions/paypal_commerce/image/icon.png"><br><p class="mt10">Paypal Commerce</p></a>
	    </div>
	    <div class="col-sm-3 h5 center">
	        <a href="#admin#rt=extension/extensions/install&extension=stripe" target="_extension">
	        <img style="width: 94px; height: 94px;" src="extensions/stripe/image/icon.png"><br><p class="mt10">Stripe</p></a>
	    </div>
	    <div class="col-sm-3 h5 center">
	        <a href="#admin#rt=extension/extensions/install&extension=sola" target="_extension">
	        <img style="height: 94px;" src="extensions/sola/image/icon.webp"><br><p class="mt10">Sola</p></a>
	    </div>
	    <div class="col-sm-3 h5 center">
	        <a style="margin-top: 36px; display: block;" href="#admin#rt=extension/extensions/payment" target="_extension">
	        <img src="admin/view/default/image/default_extension.png"><br><p class="mt10">More Payments</p></a>
	    </div>
    </div>
    ]]></value>
  </definition>
