  <definition>
    <key>paypal_selection</key>
    <value><![CDATA[
    <div class="col-md-12">
        <div class="text-center">
            <h1>Accept Payments from <br/>customers with PayPal.</h1>
            <p>
                <img alt="PayPal + AbanteCart" src="extensions/paypal_commerce/image/paypal_step.png" class="mcnImage" style="max-width:600px; padding-bottom: 0; display: inline !important; vertical-align: bottom; width:570px; align:middle;">
            </p>
        </div>

        <div style="padding: 10px 60px 30px 60px">
            <h1>PayPal: The all-in-one checkout solution</h1>
            <ul style="font-size: 14px; line-height: 1.7; margin: 0; padding-left: 24px;">
                <li>Help drive conversion by offering customers a seamless checkout experience with no setup or monthly fee</li>
                <li>Provide Buy Now Pay Later solutions to your customers</li>
                <li>Securely accept all major credit/debit cards and local payment methods with the strength of the PayPal network</li>
            </ul>
        </div>

        <div class="text-center">
            <div class="btn-group">
                <a class="btn btn-white" href="#admin#rt=extension/extensions/install&extension=paypal_commerce" target="_blank">
                    <i class="fa fa-arrow-right"></i> Learn More
                </a>
            </div>
        </div>
    </div>
    ]]></value>
  </definition>
  <definition>
