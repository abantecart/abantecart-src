<?xml version="1.0"?>
<extension>
	<id>usps</id>
	<version>1.4.3</version>
	<type>shipping</type>
	<category>shipping</category>
	<cartversions>
		<item>1.4</item>
	</cartversions>
	<priority>10</priority>
	<settings>
		<item id="usps_debug">
			<type>checkbox</type>
			<default_value>0</default_value>
		</item>
		<item id="usps_api_environment">
			<type>checkbox</type>
			<default_value>0</default_value>
		</item>
		<item id="usps_client_id">
			<type>input</type>
		</item>
		<item id="usps_client_secret">
			<type>input</type>
		</item>
		<item id="usps_test_connection">
			<type>html_template</type>
			<template>responses/extension/usps_test.tpl</template>
		</item>
		<item id="usps_payment_crid">
			<type>input</type>
			<note><![CDATA[Customer Registration ID (CRID):<span class="help">Required for USPS label generation.</span>]]></note>
		</item>
		<item id="usps_payment_mid">
			<type>input</type>
			<note><![CDATA[Mailer ID (MID):<span class="help">Required for USPS label generation.</span>]]></note>
		</item>
		<item id="usps_payment_manifest_mid">
			<type>input</type>
			<note><![CDATA[Manifest MID:<span class="help">Required for USPS label generation.</span>]]></note>
		</item>
		<item id="usps_payment_account_number">
			<type>input</type>
			<note><![CDATA[EPS Account Number:<span class="help">Required for USPS label generation.</span>]]></note>
		</item>
		<item id="usps_generate_payment_token">
			<type>html_template</type>
			<template>responses/extension/usps_test_label.tpl</template>
			<note><![CDATA[Payment Token Access:<span class="help">For label generation, USPS may require additional permissions for payment token generation on your account. Contact USPS support to enable this access.</span>]]></note>
		</item>
		<item id="usps_country">
			<type required="true">zones</type>
			<default_value config_key="config_country_id"/>
		</item>
		<item id="usps_address">
			<type required="true">input</type>
			<default_value config_key="config_address"/>
		</item>
		<item id="usps_city">
			<type required="true">input</type>
			<default_value config_key="config_city"/>
		</item>
		<item id="usps_postcode">
			<type required="true">input</type>
			<default_value config_key="config_postcode"/>
		</item>
		<item id="usps_telephone">
			<type required="true">input</type>
			<default_value config_key="config_telephone"/>
		</item>
		<item id="usps_manifest_order_status_id">
			<type>selectbox</type>
			<variants>
				<data_source>
					<model_rt>localisation/order_status</model_rt>
					<method>getOrderStatuses</method>
				</data_source>
				<fields>
					<field>order_status_id</field>
					<field>name</field>
				</fields>
			</variants>
			<default_value>3</default_value>
		</item>
		<item id="usps_domestic_1">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_2">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_3">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_4">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_5">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_6">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_domestic_7">
			<type>checkbox</type>
			<default_value>0</default_value>
		</item>
		<item id="usps_international_1">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_international_2">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_international_3">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_international_4">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_length">
			<type>input</type>
			<default_value>12</default_value>
		</item>
		<item id="usps_width">
			<type>input</type>
			<default_value>8</default_value>
		</item>
		<item id="usps_height">
			<type>input</type>
			<default_value>4</default_value>
		</item>
		<item id="usps_display_weight">
			<type>checkbox</type>
			<default_value>1</default_value>
		</item>
		<item id="usps_tax_class_id">
			<type>selectbox</type>
			<variants>
				<data_source>
					<model_rt>localisation/tax_class</model_rt>
					<method>getTaxClasses</method>
				</data_source>
				<fields>
					<field>tax_class_id</field>
					<field>title</field>
				</fields>
			</variants>
			<default_value>0</default_value>
		</item>
		<item id="usps_location_id">
			<type>selectbox</type>
			<variants>
				<item>0</item>
				<data_source>
					<model_rt>localisation/location</model_rt>
					<method>getLocations</method>
				</data_source>
				<fields>
					<field>location_id</field>
					<field>name</field>
				</fields>
			</variants>
			<default_value>0</default_value>
		</item>
		<item id="usps_sort_order">
			<type>input</type>
			<default_value>0</default_value>
		</item>
	</settings>
	<help_file><![CDATA[help.txt]]></help_file>
	<help_link><![CDATA[https://developers.usps.com/getting-started]]></help_link>
</extension>
